24d\u7684\u51c6\u5907 \u00b6 \u73af\u5883\u9009\u62e9 \u00b6 \u4eba\u8eab\u5b89\u5168 \u6c38\u8fdc\u662f\u6700\u91cd\u8981\u7684\u3002\u907f\u514d\u9009\u62e9\u5728\u5371\u9669\u7684\u573a\u6240\u8fdb\u884c\u53d1\u5c04\uff0c\u5982\u65e0\u62a4\u680f\u4fdd\u62a4\u7684\u9ad8\u7a7a\u3001\u6c34\u8fb9\uff0c\u6216\u9ad8\u538b\u7535\u7ebf\u9644\u8fd1\u7b49\u3002 \u5728\u4fdd\u8bc1\u5b89\u5168\u7684\u524d\u63d0\u4e0b\uff0c\u5c3d\u91cf\u9009\u62e9 \u7535\u78c1\u73af\u5883\u826f\u597d \u7684\u573a\u6240\u53d1\u5c04\u3002\u5c3d\u91cf\u9009\u62e9\u5f00\u9614\u533a\u57df\u3001\u6d77\u62d4\u9ad8\u5904\uff0c\u51cf\u5c11\u906e\u6321\u4e0e\u5e72\u6270\u3002\u907f\u514d\u5728\u5ba4\u5185\u3001\u7535\u74f6\u8f66\u505c\u8f66\u533a\u9644\u8fd1\u53d1\u5c04\u3002 \u68c0\u67e5\u8bbe\u5907\u4e0e\u5929\u9988\u7cfb\u7edf \u00b6 \u786e\u8ba4\u786c\u4ef6\u60c5\u51b5\uff1a \u8bbe\u5907 \u4f9b\u7535\u59a5\u5f53 \u6216 \u50a8\u5b58\u7535\u91cf\u5145\u8db3 \u3002\u8c28\u9632\u77ed\u8def\u7b49\u7535\u6c14\u9690\u60a3\u3002 \u8bbe\u5907\u4e0e \u5929\u7ebf\u8fde\u63a5 \u59a5\u5f53\u3002\u5fc5\u8981\u65f6\uff0c\u6d4b\u91cf\u5929\u7ebf\u5728\u76ee\u6807\u9891\u7387\u7684\u9a7b\u6ce2\u6bd4\uff0c\u5e76\u8fdb\u884c\u8c03\u6574\uff08\u5982\u63a5\u5165\u5929\u8c03\uff0c\u6539\u53d8\u957f\u5ea6\uff09\u3002 \u5176\u4ed6\u786c\u4ef6\u9690\u60a3\u3002\u4f8b\u5982\uff0c\u5f53\u4f7f\u7528\u4e09\u811a\u67b6\u56fa\u5b9a\u5929\u7ebf\u65f6\uff0c\u786e\u4fdd\u4e09\u811a\u67b6\u87ba\u6813\u56fa\u5b9a\u59a5\u5f53\u3002 \u786e\u8ba4\u53d1\u5c04\u53c2\u6570\uff1a \u6b63\u786e\u8bbe\u7f6e \u53d1\u5c04\u9891\u7387\uff08TX\uff09\u3001\u6536\u542c\uff08RX\uff09 \u9891\u7387\u3002 \u6b63\u786e\u8bbe\u7f6e \u53d1\u5c04\u4e9a\u97f3\u3001\u63a5\u6536\u4e9a\u97f3 \u9891\u7387\uff08\u4e00\u4e9b\u4e2d\u7ee7\u53f0\u53ef\u80fd\u6709\u76f8\u5e94\u53c2\u6570\u8981\u6c42\uff09\u3002 \u8bbe\u7f6e \u9002\u5f53\u7684\u53d1\u5c04\u529f\u7387 \u3002\u8fc7\u5927\u7684\u529f\u7387\u53ef\u80fd\u9020\u6210\u63a5\u6536\u8bbe\u5907\u8fc7\u8f7d\uff0c\u8fc7\u5c0f\u7684\u529f\u7387\u5219\u4f1a\u5bfc\u81f4\u6b20\u4f73\u7684\u901a\u4fe1\u6548\u679c\u3002 \u5b88\u542c\u548c\u8be2\u95ee \u00b6 \u5f53\u521a\u521a\u8c03\u81f3\u76ee\u6807\u9891\u7387\u65f6\uff0c\u4f60\u65e0\u6cd5\u76f4\u63a5\u786e\u5b9a\u9891\u7387\u4e0a\u662f\u5426\u6709\u4eba\u6b63\u5728\u901a\u8054\u3002\u56e0\u6b64\uff0c\u7acb\u523b\u8d38\u7136\u547c\u53eb\u5f88\u6709\u53ef\u80fd\u5e72\u6270\u4ed6\u4eba\u7684\u901a\u8054\u3002 \u63a8\u8350\u6d41\u7a0b\u4e3a\uff1a \u5b88\u542c \u3002\u5728\u9891\u7387\u4e0a\u4fdd\u6301\u9759\u9ed8\uff0c\u6301\u7eed\u5b88\u542c1\uff5e2\u5206\u949f\uff0c\u786e\u8ba4\u6ca1\u6709\u80fd\u591f\u76f4\u63a5\u542c\u5230\u7684\u4fe1\u53f7\u3002 \u8be2\u95ee \u3002\u5728\u9891\u7387\u4e0a\u8be2\u95ee\u201c\u6709\u4eba\u5728\u4f7f\u7528\u9891\u7387\u5417\uff1f / Anyone using the frequency?\u201d\u3002\u5982\u679c\u6709\u4eba\u56de\u5e94\u201c\u6709\u4eba / Yes\u201d\u7b49\uff0c\u5219\u5e94\u8be5\u653e\u5f03\u6b64\u6b21\u547c\u53eb\uff0c\u5e76\u8003\u8651\u66f4\u6539\u9891\u7387\u6216\u7b49\u5f85\u5f53\u524d\u901a\u8054\u7ed3\u675f\u540e\u518d\u547c\u53eb\uff1b\u5982\u679c\u65e0\u4eba\u56de\u5e94\uff0c\u5219\u53ef\u4ee5\u5f00\u59cb\u53d1\u8d77\u547c\u53eb\u3002 \u8bf7\u6ce8\u610f\uff0c\u5b88\u542c\u548c\u8be2\u95ee\u53ea\u662f\u80fd\u591f\u8f83\u5927\u7a0b\u5ea6\u51cf\u5c0f\u6253\u65ad\u4ed6\u4eba\u7684\u98ce\u9669\uff0c\u8fd9\u79cd\u68c0\u67e5 \u5e76\u4e0d\u662f100%\u51c6\u786e\u7684 \u3002 \u5e7f\u6cdb\u547c\u53ebCQ \u00b6 \u8bdd\u97f3\u6a21\u5f0f\u7684\u547c\u53eb\u683c\u5f0f\u5927\u81f4\u5982\u4e0b\uff1a CQ CQ CQ\uff0c\u8fd9\u91cc\u662f [\u547c\u53f7\u7b2c1\u904d] [\u547c\u53f7\u7b2c2\u904d] [\u547c\u53f7\u7b2c3\u904d]\uff0c\u547c\u53eb\u9891\u7387\u4e0a\u7684\u53cb\u53f0\u3002 CQ CQ CQ, this is [Callsign #1] [Callsign #2] [Callsign #3], calling CQ and standing by. \u5e7f\u6cdb\u547c\u53eb\u4e2d\uff0c\u5efa\u8bae\u8bf43\u6b21\u201cCQ\u201d\u548c3\u6b21\u547c\u53f7\u3002 \u5176\u4e2d\uff0c\u81f3\u5c11\u67091\u904d\u547c\u53f7\u4e3a \u5b57\u6bcd\u89e3\u91ca\u6cd5 \uff0c\u4ee5\u4fdd\u8bc1\u5bf9\u65b9\u5728\u4f20\u64ad\u4e0d\u4f73\u7684\u60c5\u51b5\u4e0b\u4e5f\u80fd\u6b63\u786e\u6284\u6536\u547c\u53f7\u3002 \u81f3\u4e8e\u6700\u540e\u7684\u201c\u547c\u53eb\u9891\u7387\u4e0a\u7684\u53cb\u53f0\u201d\uff0c\u5e76\u4e0d\u91cd\u8981\uff0c\u5b8c\u5168\u53ef\u4ee5\u6539\u4e3a\u5176\u4ed6\u8bf4\u6cd5\u3002 \u6709\u4e9b\u7231\u597d\u8005\u4e0d\u559c\u6b22\u4f7f\u7528\u5b57\u6bcd\u89e3\u91ca\u6cd5\u62a5\u547c\u53f7\uff0c\u867d\u7136\u8fd9\u5e76\u4e0d\u8fdd\u89c4\uff0c\u4f46\u8fd9\u662f\u5f88\u4e0d\u597d\u7684\u4e60\u60ef\u3002\u5bf9\u4e8e\u65b0\u6765\u4e4d\u5230\u7684\u7231\u597d\u8005\u800c\u8a00\uff0c\u5c31\u65e0\u6cd5\u5f97\u77e5\u5f53\u524d\u6b63\u5728\u53d1\u5c04\u7684\u7535\u53f0\u547c\u53f7\u4e86\u3002 \u5728\u53f0\u7f51\u70b9\u540d\u7b49\u6d3b\u52a8\u4e2d\uff0c\u4e0d\u4f7f\u7528\u5b57\u6bcd\u89e3\u91ca\u6cd5\u5f88\u53ef\u80fd\u4f1a\u5bfc\u81f4\u4e3b\u63a7\u6284\u6536\u9519\u8bef\u3002\u56e0\u6b64\uff0c\u4e3a\u4e86\u63d0\u9ad8\u901a\u8054\u6548\u7387\u548c\u8d28\u91cf\uff0c\u4f7f\u7528\u5b57\u6bcd\u89e3\u91ca\u6cd5\u662f\u88ab\u63d0\u5021\u7684\u3002 \u56de\u5e94CQ \u00b6 \u5047\u8bbe\u4f60\u5728\u9891\u7387\u4e0a\u542c\u5230\u4ed6\u4eba\u6b63\u5728\u5e7f\u6cdb\u547c\u53eb\uff0c\u800c\u4f60\u60f3\u8981\u56de\u5e94CQ\u3002\u6b64\u65f6\uff0c\u53ea\u9700\u8981\u53d1\u51fa\u81ea\u5df1\u7684\u547c\u53f7\u5373\u53ef\u3002 \u4fdd\u9669\u8d77\u89c1\uff0c\u547c\u53f7\u53ef\u4ee5\u53d1\u90013\u6b21\uff1b\u540c\u6837\uff0c\u5efa\u8bae\u4f7f\u7528\u5b57\u6bcd\u89e3\u91ca\u6cd5\u4ee5\u4fbf\u5bf9\u65b9\u53ef\u4ee5\u6b63\u786e\u6284\u6536\u3002 \u5982\u679c\u4f60\u4f5c\u4e3a\u56de\u5e94\u65b9\u6ca1\u6709\u6284\u6536\u6e05\u695a\u5bf9\u65b9\u7684\u547c\u53f7\uff0c\u53ef\u4ee5\u8fdb\u884c\u8be2\u95ee\uff1a \u54ea\u4f4d\u53cb\u53f0\u5728\u547c\u53eb\uff1f\u8bf7\u518d\u8fc7\u6765\u3002 / Again please? \u5982\u679c\u4f60\u4f5c\u4e3a\u547c\u53eb\u65b9\u6ca1\u6709\u6284\u6536\u6e05\u695a\u5bf9\u65b9\u7684\u547c\u53f7\